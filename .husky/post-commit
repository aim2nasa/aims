#!/bin/sh

# 🔒 파일 기반 락으로 재진입 방지 (무한 루프 방지)
LOCK_FILE=".git/version_bump.lock"
CURRENT_SHA=$(git rev-parse HEAD)

# 락 파일이 존재하고, 현재 커밋 SHA와 같으면 스킵 (amend로 인한 재실행)
if [ -f "$LOCK_FILE" ]; then
  LOCK_SHA=$(cat "$LOCK_FILE")
  # 락 파일 삭제 (다음 커밋을 위해)
  rm -f "$LOCK_FILE"
  echo "⏭️  Skipping version bump (already processed)"
  exit 0
fi

# 마지막 커밋 메시지 가져오기
COMMIT_MSG=$(git log -1 --pretty=%B)

# 버전 업데이트 커밋인지 확인 (무한 루프 방지)
if echo "$COMMIT_MSG" | grep -q "^chore: 버전"; then
  echo "⏭️  Skipping version bump (already a version commit)"
  exit 0
fi

# frontend/aims-uix3 변경사항이 있는지 확인
if ! git diff HEAD~1 --name-only | grep -q "^frontend/aims-uix3/"; then
  echo "ℹ️  Skipping version bump (no frontend changes)"
  exit 0
fi

# feat: 또는 fix: 커밋인지 확인
if echo "$COMMIT_MSG" | grep -q "^feat:"; then
  echo "🔼 Auto-bumping minor version (feat commit)..."
  # 락 파일 생성 (amend 후 재실행 방지)
  echo "$CURRENT_SHA" > "$LOCK_FILE"
  (cd frontend/aims-uix3 && npm version minor -m 'chore: 버전 %s (auto)' --no-git-tag-version) || exit 1
  git add frontend/aims-uix3/package.json frontend/aims-uix3/package-lock.json frontend/package-lock.json
  git commit --amend --no-edit --no-verify
  echo "✅ Minor version bumped!"
elif echo "$COMMIT_MSG" | grep -q "^fix:"; then
  echo "🔼 Auto-bumping patch version (fix commit)..."
  # 락 파일 생성 (amend 후 재실행 방지)
  echo "$CURRENT_SHA" > "$LOCK_FILE"
  (cd frontend/aims-uix3 && npm version patch -m 'chore: 버전 %s (auto)' --no-git-tag-version) || exit 1
  git add frontend/aims-uix3/package.json frontend/aims-uix3/package-lock.json frontend/package-lock.json
  git commit --amend --no-edit --no-verify
  echo "✅ Patch version bumped!"
else
  echo "ℹ️  Skipping version bump (not feat/fix commit)"
fi

exit 0
