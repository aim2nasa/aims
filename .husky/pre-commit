#!/bin/sh

echo "🔍 Running pre-commit checks..."

# ==================== 1단계: 서비스별 버전 자동 증가 ====================
BUMP_SCRIPT="scripts/bump_version.py"

# Python 감지: 존재 여부가 아닌 실제 실행 가능 여부로 판단
# (Windows Store 앱 별칭이 command -v를 속이는 문제 방지)
if py -c "pass" >/dev/null 2>&1; then
  BUMP_PY="py"
elif python3 -c "pass" >/dev/null 2>&1; then
  BUMP_PY="python3"
elif python -c "pass" >/dev/null 2>&1; then
  BUMP_PY="python"
else
  BUMP_PY=""
  echo "⚠️  Python을 찾을 수 없습니다. 버전 자동 증가를 건너뜁니다."
fi

if [ -n "$BUMP_PY" ] && [ -f "$BUMP_SCRIPT" ]; then
  if git diff --cached --name-only | grep -q "^tools/auto_clicker_v2/"; then
    echo "[AutoClicker] 변경 감지 - 버전 자동 증가"
    $BUMP_PY $BUMP_SCRIPT tools/auto_clicker_v2/VERSION
    git add tools/auto_clicker_v2/VERSION
  fi

  if git diff --cached --name-only | grep -q "^backend/api/aims_api/"; then
    echo "[aims_api] 변경 감지 - 버전 자동 증가"
    $BUMP_PY $BUMP_SCRIPT backend/api/aims_api/VERSION
    git add backend/api/aims_api/VERSION
  fi

  if git diff --cached --name-only | grep -q "^backend/api/aims_rag_api/"; then
    echo "[aims_rag_api] 변경 감지 - 버전 자동 증가"
    $BUMP_PY $BUMP_SCRIPT backend/api/aims_rag_api/VERSION
    git add backend/api/aims_rag_api/VERSION
  fi

  if git diff --cached --name-only | grep -q "^backend/api/annual_report_api/"; then
    echo "[annual_report_api] 변경 감지 - 버전 자동 증가"
    $BUMP_PY $BUMP_SCRIPT backend/api/annual_report_api/VERSION
    git add backend/api/annual_report_api/VERSION
  fi

  if git diff --cached --name-only | grep -q "^backend/api/pdf_proxy/"; then
    echo "[pdf_proxy] 변경 감지 - 버전 자동 증가"
    $BUMP_PY $BUMP_SCRIPT backend/api/pdf_proxy/VERSION
    git add backend/api/pdf_proxy/VERSION
  fi
fi

# ==================== 2단계: Backend Python 구문 검사 ====================

STAGED_PY_FILES=$(git diff --cached --name-only -- '*.py' | grep -v '__pycache__' | grep -v '.pyc' || true)

if [ -n "$STAGED_PY_FILES" ] && [ -n "$BUMP_PY" ]; then
  echo ""
  echo "🐍 Checking Python syntax..."
  PY_FAILED=0
  for pyfile in $STAGED_PY_FILES; do
    if [ -f "$pyfile" ]; then
      if ! $BUMP_PY -m py_compile "$pyfile" 2>/dev/null; then
        echo "  ❌ Syntax error: $pyfile"
        PY_FAILED=1
      fi
    fi
  done

  if [ "$PY_FAILED" = "1" ]; then
    echo "❌ Python syntax check failed!"
    exit 1
  fi
  echo "  ✅ Python syntax OK"
fi

# ==================== 3단계: Backend 모듈별 선택 테스트 (서버 SSH) ====================

STAGED_BACKEND_FILES=$(git diff --cached --name-only -- 'backend/*' || true)

if [ -n "$STAGED_BACKEND_FILES" ]; then
  echo ""
  echo "🧪 Running backend tests on server (module-selective)..."

  # shared-schema 변경 → 전체 모듈 테스트 (의존 모듈 전체 영향)
  SHARED_SCHEMA_CHANGED=0
  if echo "$STAGED_BACKEND_FILES" | grep -q "^backend/shared/"; then
    SHARED_SCHEMA_CHANGED=1
    echo "  ⚠️  shared-schema 변경 감지 → 전체 모듈 테스트"
  fi

  # SSH 연결 확인 (5초 타임아웃)
  if ssh -o ConnectTimeout=5 -o BatchMode=yes rossi@100.110.215.65 'echo OK' >/dev/null 2>&1; then

    # aims_api 테스트
    if [ "$SHARED_SCHEMA_CHANGED" = "1" ] || echo "$STAGED_BACKEND_FILES" | grep -q "^backend/api/aims_api/"; then
      echo "  📦 Testing aims_api..."
      if ! ssh -o ConnectTimeout=10 rossi@100.110.215.65 'cd ~/aims/backend/api/aims_api && npm run test:ci 2>&1' ; then
        echo "  ❌ aims_api tests failed!"
        exit 1
      fi
      echo "  ✅ aims_api tests passed"
    fi

    # annual_report_api 테스트
    if [ "$SHARED_SCHEMA_CHANGED" = "1" ] || echo "$STAGED_BACKEND_FILES" | grep -q "^backend/api/annual_report_api/"; then
      echo "  📦 Testing annual_report_api..."
      if ! ssh -o ConnectTimeout=10 rossi@100.110.215.65 'cd ~/aims/backend/api/annual_report_api && source venv/bin/activate && python3 -m pytest -v --tb=short 2>&1' ; then
        echo "  ❌ annual_report_api tests failed!"
        exit 1
      fi
      echo "  ✅ annual_report_api tests passed"
    fi

    # document_pipeline 테스트
    if [ "$SHARED_SCHEMA_CHANGED" = "1" ] || echo "$STAGED_BACKEND_FILES" | grep -q "^backend/api/document_pipeline/"; then
      echo "  📦 Testing document_pipeline..."
      if ! ssh -o ConnectTimeout=10 rossi@100.110.215.65 'cd ~/aims/backend/api/document_pipeline && source venv/bin/activate && python3 -m pytest tests/ -q --tb=short 2>&1' ; then
        echo "  ❌ document_pipeline tests failed!"
        exit 1
      fi
      echo "  ✅ document_pipeline tests passed"
    fi

    # aims_mcp TypeScript 컴파일 체크
    if [ "$SHARED_SCHEMA_CHANGED" = "1" ] || echo "$STAGED_BACKEND_FILES" | grep -q "^backend/api/aims_mcp/"; then
      echo "  📦 Checking aims_mcp TypeScript..."
      if ! ssh -o ConnectTimeout=10 rossi@100.110.215.65 'cd ~/aims/backend/api/aims_mcp && npx tsc --noEmit 2>&1' ; then
        echo "  ❌ aims_mcp TypeScript check failed!"
        exit 1
      fi
      echo "  ✅ aims_mcp TypeScript check passed"
    fi

    # 어떤 모듈도 매칭되지 않은 경우 (embedding, shared 등 기타 백엔드 변경)
    if [ "$SHARED_SCHEMA_CHANGED" = "0" ] && \
       ! echo "$STAGED_BACKEND_FILES" | grep -q "^backend/api/aims_api/" && \
       ! echo "$STAGED_BACKEND_FILES" | grep -q "^backend/api/annual_report_api/" && \
       ! echo "$STAGED_BACKEND_FILES" | grep -q "^backend/api/document_pipeline/" && \
       ! echo "$STAGED_BACKEND_FILES" | grep -q "^backend/api/aims_mcp/"; then
      echo "  ℹ️  변경된 백엔드 모듈에 대한 테스트 없음 (스킵)"
    fi

  else
    echo "  ⚠️  SSH 연결 불가 (100.110.215.65) - 백엔드 테스트 건너뜀"
    echo "  ⚠️  커밋 전에 수동으로 테스트를 실행하세요: node scripts/test-all.js"
  fi
fi

# ==================== 4단계: AI 어시스턴트 변경 경고 ====================
# MCP 도구 또는 chatService.js 변경 시 regression 테스트 추가 여부 확인

STAGED_FILES=$(git diff --cached --name-only)

# docs/*.md 변경만 있는 경우 스킵
NON_DOC_FILES=$(echo "$STAGED_FILES" | grep -v '\.md$' | grep -v '^docs/' || true)
if [ -n "$NON_DOC_FILES" ]; then

  AI_CORE_CHANGED=0
  # MCP 도구 파일 변경 감지
  if echo "$STAGED_FILES" | grep -q "^backend/api/aims_mcp/src/tools/"; then
    AI_CORE_CHANGED=1
  fi
  # chatService.js 변경 감지
  if echo "$STAGED_FILES" | grep -q "^backend/api/aims_api/lib/chatService.js"; then
    AI_CORE_CHANGED=1
  fi

  if [ "$AI_CORE_CHANGED" = "1" ]; then
    # 테스트 파일도 함께 변경되었는지 확인
    TEST_CHANGED=0
    if echo "$STAGED_FILES" | grep -q "^backend/api/aims_mcp/src/__tests__/"; then
      TEST_CHANGED=1
    fi
    if echo "$STAGED_FILES" | grep -q "^backend/api/aims_api/__tests__/"; then
      TEST_CHANGED=1
    fi
    if echo "$STAGED_FILES" | grep -q "^tools/ai_assistant_regression/"; then
      TEST_CHANGED=1
    fi

    if [ "$TEST_CHANGED" = "0" ]; then
      echo ""
      echo "  ============================================================"
      echo "  MCP 도구/시스템 프롬프트 변경됨 -- regression 테스트 추가 필요"
      echo "  대상: tools/ai_assistant_regression/regression_cases.json"
      echo "        backend/api/aims_mcp/src/__tests__/"
      echo "        backend/api/aims_api/__tests__/"
      echo "  ============================================================"
      echo ""
      echo "  테스트 없이 커밋하려면: git commit --no-verify"
      exit 1
    fi
  fi

fi

# ==================== 5단계: Frontend 검사 ====================

STAGED_FRONTEND_FILES=$(git diff --cached --name-only -- 'frontend/aims-uix3/*' || true)

if [ -z "$STAGED_FRONTEND_FILES" ]; then
  echo ""
  echo "ℹ️  Skipping aims-uix3 checks (no staged changes)."
else
  # JS/TS 소스가 변경되지 않았다면 CSS/자원만 수정된 것으로 보고 빌드/테스트 생략
  if ! printf '%s\n' "$STAGED_FRONTEND_FILES" | grep -Eq '\.(ts|tsx|js|jsx|cjs|mjs|json)$'; then
    echo ""
    echo "ℹ️  Skipping aims-uix3 build/tests (no JS/TS changes detected)."
  else
    echo ""
    echo "📦 Building frontend/aims-uix3..."
    (cd frontend/aims-uix3 && npm run build) || exit 1

    echo "🧪 Running frontend full regression tests..."
    (cd frontend/aims-uix3 && npm test -- --run) || exit 1
  fi
fi

echo ""
echo "✅ All pre-commit checks passed!"
