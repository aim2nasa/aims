#!/bin/sh

echo "🔍 Running pre-commit checks..."

# ==================== 서비스별 버전 자동 증가 ====================
BUMP_SCRIPT="scripts/bump_version.py"

# Python 감지: 존재 여부가 아닌 실제 실행 가능 여부로 판단
# (Windows Store 앱 별칭이 command -v를 속이는 문제 방지)
if py -c "pass" >/dev/null 2>&1; then
  BUMP_PY="py"
elif python3 -c "pass" >/dev/null 2>&1; then
  BUMP_PY="python3"
elif python -c "pass" >/dev/null 2>&1; then
  BUMP_PY="python"
else
  BUMP_PY=""
  echo "⚠️  Python을 찾을 수 없습니다. 버전 자동 증가를 건너뜁니다."
fi

if [ -n "$BUMP_PY" ] && [ -f "$BUMP_SCRIPT" ]; then
  if git diff --cached --name-only | grep -q "^tools/auto_clicker_v2/"; then
    echo "[AutoClicker] 변경 감지 - 버전 자동 증가"
    $BUMP_PY $BUMP_SCRIPT tools/auto_clicker_v2/VERSION
    git add tools/auto_clicker_v2/VERSION
  fi

  if git diff --cached --name-only | grep -q "^backend/api/aims_api/"; then
    echo "[aims_api] 변경 감지 - 버전 자동 증가"
    $BUMP_PY $BUMP_SCRIPT backend/api/aims_api/VERSION
    git add backend/api/aims_api/VERSION
  fi

  if git diff --cached --name-only | grep -q "^backend/api/aims_rag_api/"; then
    echo "[aims_rag_api] 변경 감지 - 버전 자동 증가"
    $BUMP_PY $BUMP_SCRIPT backend/api/aims_rag_api/VERSION
    git add backend/api/aims_rag_api/VERSION
  fi

  if git diff --cached --name-only | grep -q "^backend/api/annual_report_api/"; then
    echo "[annual_report_api] 변경 감지 - 버전 자동 증가"
    $BUMP_PY $BUMP_SCRIPT backend/api/annual_report_api/VERSION
    git add backend/api/annual_report_api/VERSION
  fi

  if git diff --cached --name-only | grep -q "^backend/api/pdf_proxy/"; then
    echo "[pdf_proxy] 변경 감지 - 버전 자동 증가"
    $BUMP_PY $BUMP_SCRIPT backend/api/pdf_proxy/VERSION
    git add backend/api/pdf_proxy/VERSION
  fi
fi

# ==================== Frontend 검사 ====================

STAGED_FRONTEND_FILES=$(git diff --cached --name-only -- 'frontend/aims-uix3/*')

if [ -z "$STAGED_FRONTEND_FILES" ]; then
  echo "ℹ️  Skipping aims-uix3 checks (no staged changes)."
  exit 0
fi

# JS/TS 소스가 변경되지 않았다면 CSS/자원만 수정된 것으로 보고 빌드/테스트 생략
if ! printf '%s\n' "$STAGED_FRONTEND_FILES" | grep -Eq '\.(ts|tsx|js|jsx|cjs|mjs|json)$'; then
  echo "ℹ️  Skipping aims-uix3 build/tests (no JS/TS changes detected)."
  exit 0
fi

echo "📦 Building frontend/aims-uix3..."
(cd frontend/aims-uix3 && npm run build) || exit 1

echo "🧪 Running tests for changed files..."
(cd frontend/aims-uix3 && npm test -- --run --changed) || exit 1

echo "✅ All checks passed!"
