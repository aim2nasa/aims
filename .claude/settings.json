{
  "permissions": {
    "allow": [
      "Edit(/.claude/skills/compact-fix/**)",
      "Edit(/.claude/skills/ace-process/**)",
      "Bash(git merge:*)",
      "Bash(git branch:*)",
      "Edit(/.claude/skills/full-deploy/**)",
      "Edit(/.claude/skills/bug/**)",
      "Bash(gh issue:*)",
      "Bash(rm -f .dev-verified)",
      "Bash(bash .git/hooks/pre-commit)",
      "Bash(gh api:*)",
      "Bash(gh repo:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "py \"d:/aims/scripts/pre_commit_review.py\"",
            "timeout": 180,
            "statusMessage": "근본적 해결 검증 + 테스트 실행 중..."
          }
        ]
      }
    ]
  }
}
