# Document Pipeline Environment Variables

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=docupload

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# File Storage
FILE_BASE_PATH=/data/files

# OpenAI (Required for DocSummary)
OPENAI_API_KEY=sk-your-api-key-here

# Upstage (Required for DocOCR - Phase 2)
UPSTAGE_API_KEY=

# Slack (Optional - for error notifications)
SLACK_WEBHOOK_URL=

# Google Sheets (Optional - for error logging)
GOOGLE_SHEETS_ID=

# Internal API — 키는 .env.shared에서 관리
WEBHOOK_API_KEY=
INTERNAL_API_KEY=
AIMS_API_URL=http://localhost:3010
