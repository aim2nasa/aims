# 네이버 클라우드 Maps API 인증 정보 (Application 인증키)
NAVER_MAP_ACCESS_KEY=your_access_key_here
NAVER_MAP_SECRET_KEY=your_secret_key_here

# JWT 인증 설정
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# 세션 설정
SESSION_SECRET=your_session_secret_here

# 카카오 OAuth 설정
KAKAO_CLIENT_ID=your_kakao_client_id_here
KAKAO_CLIENT_SECRET=
KAKAO_CALLBACK_URL=https://aims.giize.com/api/auth/kakao/callback

# 프론트엔드 URL (프로덕션)
FRONTEND_URL=https://aims.giize.com
