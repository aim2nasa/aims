{
  "name": "aims-mcp",
  "version": "1.0.0",
  "description": "AIMS MCP Server - LLM access to insurance agent data",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js",
    "start:http": "MCP_MODE=http node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run --exclude='**/user-simulation.e2e.test.ts'",
    "test:watch": "vitest --exclude='**/user-simulation.e2e.test.ts'",
    "test:e2e": "vitest run src/user-simulation.e2e.test.ts",
    "test:all": "vitest run"
  },
  "dependencies": {
    "@aims/shared-schema": "file:../../shared/schema",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "mongodb": "^6.18.0",
    "zod": "^3.23.8",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "typescript": "^5.3.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
