      "id": "c1be6402-7543-4042-ac72-04c6dd869f7a",
      "name": "OpenAI Chat Model",
      "credentials": {
        "openAiApi": {
          "id": "yC6LpoMbPIyu7vwv",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const text = $json.body.full_text || '';\n\n// 길이 확인\nconst length = text.length;\n\n// 앞 5000자만 잘라서 요약에 사용\nconst limitedText = text.substring(0, 5000);\n\nreturn [{\n  json: {\n    full_text: text,\n    limitedText,\n    length,\n    truncated: text.length > 5000\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        496,
        -128
      ],
      "id": "860f264c-7ccd-442a-b9bb-5f3c0c81cbea",
      "name": "LimitText"
    },
    {
      "parameters": {
        "options": {
          "responseCode": 200
        }
      },
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.4,
      "position": [
        1344,
        -128
      ],
      "id": "b3257167-2a7c-4119-95a9-dbf49ca7cb4a",
      "name": "Summary Return"
    },
    {
      "parameters": {
        "jsCode": "let aiOutput = $json.output;\n\n// 1. output이 문자열이면 파싱 시도\nif (typeof aiOutput === \"string\") {\n  try {\n    aiOutput = JSON.parse(aiOutput);\n  } catch (e) {\n    // 파싱 실패하면 그대로 둠\n  }\n}\n\n// 2. summary 텍스트 결정\nlet summary = \"\";\nif (typeof aiOutput === \"object\" && aiOutput !== null && aiOutput.summary) {\n  summary = aiOutput.summary;     // JSON 객체 안에 summary 키가 있는 경우\n} else {\n  summary = String(aiOutput);     // 그냥 문자열인 경우\n}\n\n// 3. summary와 length를 리턴\nreturn [{\n  json: {\n    summary,\n    length: summary.length,\n    truncated: $('LimitText').first().json.truncated\n  }\n}];"
      },
