    },
    {
      "parameters": {
        "jsCode": "const response = $json;\n\n// ✅ 429: 요청 제한 초과\nif (response.status === 429) {\n  return [{\n    json: {\n      error: true,\n      status: 429,\n      userMessage: \"❌ OCR 요청 제한 초과: 잠시 후 다시 시도하세요.\"\n    }\n  }];\n}\n\n// ✅ 413: 문서 페이지 초과\nif (response.status === 413 || response.error?.message?.includes('too many pages')) {\n  return [{\n    json: {\n      error: true,\n      status: 413,\n      userMessage: \"❌ OCR 실패: 문서 페이지가 너무 많습니다. 30페이지 이하 문서만 지원됩니다.\"\n    }\n  }];\n}\n\n// ✅ 그 외 에러 → Upstage 메시지 그대로 전달\nif (response.error) {\n  return [{\n    json: {\n      error: true,\n      status: response.status || 500,\n      userMessage: response.error.message || \"❌ OCR 처리 실패\"\n    }\n  }];\n}\n\n// ✅ 정상 응답\nreturn [{\n  json: {\n    error: false,\n    ...response\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -432,
        212
      ],
      "id": "c610eb72-b0ed-44bd-9692-6e7b122dada3",
      "name": "Check OCR Error"
    },
    {
      "parameters": {
        "jsCode": "const pages = $json.pages || [];\n\n// ✅ 전체 텍스트(full_text)\nlet fullText = \"\";\nfor (const page of pages) {\n  fullText += (page.text || \"\") + \"\\n\\n\";\n}\n\n// ✅ 요약에만 사용할 제한 텍스트(limitedText)\nlet limitedText = \"\";\nfor (const page of pages.slice(0, 5)) {\n  limitedText += (page.text || \"\") + \"\\n\\n\";\n}\n\nreturn [{\n  json: {\n    confidence: $input.first().json.confidence,\n    full_text: fullText.trim(),      // ✅ DB 저장용 전체 텍스트\n    limitedText: limitedText.trim()  // ✅ 요약용 5p 제한 텍스트\n  }\n}];\n"
      },
