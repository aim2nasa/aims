    {
      "parameters": {
        "jsCode": "let aiOutput = $node[\"AI Agent\"].json.output;\n\n// ✅ output이 문자열이면 JSON 파싱 시도\nif (typeof aiOutput === \"string\") {\n  try {\n    aiOutput = JSON.parse(aiOutput);\n  } catch (e) {\n    // 파싱 실패하면 문자열 그대로 유지\n  }\n}\n\nreturn [{\n  json: {\n    confidence: $node[\"Limit & Merge Pages\"].json.confidence,    // OCR 신뢰도\n    full_text: $node[\"Limit & Merge Pages\"].json.full_text,      // DB 저장용 전체 텍스트\n    summary: aiOutput.summary || aiOutput                       // summary 있으면 출력, 없으면 전체 반환\n  }\n}];\n"
      },
