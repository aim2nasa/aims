    {
      "parameters": {
        "mode": "raw",
        "jsonOutput": "={\n  \"status\": 200,\n  \"error\": false,\n  \"userMessage\": \"OCR 성공\",\n  \"confidence\": {{ $json.confidence }},\n  \"summary\": {{ JSON.stringify($json.summary) }},\n  \"full_text\": {{ JSON.stringify($json.full_text) }}\n}",
        "options": {}
      },
