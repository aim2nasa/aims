    {
      "parameters": {
        "jsCode": "function randomToken(len = 8) {\n  const chars = 'abcdefghijklmnopqrstuvwxyz0123456789';\n  let out = '';\n  for (let i = 0; i < len; i++) {\n    out += chars[Math.floor(Math.random() * chars.length)];\n  }\n  return out;\n}\n\n// 현재 시각\nconst now = new Date();\nconst yyyy = now.getFullYear();\nconst mm = ('0' + (now.getMonth() + 1)).slice(-2);\nconst dd = ('0' + now.getDate()).slice(-2);\nconst hh = ('0' + now.getHours()).slice(-2);\nconst min = ('0' + now.getMinutes()).slice(-2);\nconst ss = ('0' + now.getSeconds()).slice(-2);\n\n// YYMMDDhhmmss 타임스탬프\nconst timestamp = `${String(yyyy).slice(-2)}${mm}${dd}${hh}${min}${ss}`;\nconst token = randomToken(8);\n\n// 사용자가 업로드한 원본 파일명 (개행 제거)\nconst originalName = $binary.file?.fileName?.replace(/[\\n\\r]/g, '') || 'unknown';\n\n// 원본 파일명에서 확장자 추출 (있으면 유지, 없으면 빈 문자열)\nlet ext = '';\nconst extMatch = originalName.match(/\\.[0-9A-Za-z]+$/);\nif (extMatch) {\n  ext = extMatch[0]; // 예: \".jpeg\"\n}\n\n// 최종 저장 이름: YYMMDDhhmmss_random + 확장자(있으면)\nconst saveName = `${timestamp}_${token}${ext}`;\n\n// 최종 폴더 (/data/files/YYYY/MM)\nconst folder = `/data/files/${yyyy}/${mm}`;\n\n// 최종 경로\nconst destPath = `${folder}/${saveName}`;\n\nreturn [{\n  json: {\n    tmpPath: $json.filePath,  // 임시 저장 파일 경로\n    folder,                   // 최종 폴더\n    destPath,                 // 최종 경로\n    saveName,                 // 최종 파일명\n    originalName              // 원본 업로드 파일명\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
