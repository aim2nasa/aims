      "id": "b36a1413-b66b-4d0c-9c6d-b633e2fdebc2",
      "name": "Respond with Search Results"
    },
    {
      "parameters": {
        "jsCode": "const query = $json.body.query || '';\nconst id = $json.body.id || '';\nconst mode = ($json.body.mode || 'OR').toUpperCase();\n\nlet finalQuery = {};\nlet isIdSearch = false; // ID 검색 여부를 판단하는 플래그\n\n// 1. ID가 존재하는 경우\nif (id) {\n  // ID 검색 쿼리 객체 생성\n  // MongoDB Extended JSON 형식의 \"$oid\"를 사용\n  finalQuery = { _id: { \"$oid\": id } };\n  isIdSearch = true;\n} \n// 2. ID가 없고 키워드가 존재하는 경우 (기존 로직)\nelse if (query.trim().length > 0) {\n  const keywords = query\n    .split(' ')\n    .map(k => k.trim())\n    .filter(k => k.length > 0);\n\n  const fields = [\n    'originalName',\n    'ocr.full_text',\n    'ocr.summary',\n    'meta.filename'\n  ];\n\n  const buildSingleKeywordQuery = (keyword) =>\n    fields.map(field => ({ [field]: { $regex: keyword, $options: 'i' } }));\n\n  if (mode === 'AND') {\n    finalQuery = {\n      $and: keywords.map(kw => ({ $or: buildSingleKeywordQuery(kw) }))\n    };\n  } else {\n    finalQuery = {\n      $or: keywords.flatMap(kw => buildSingleKeywordQuery(kw))\n    };\n  }\n}\n// 3. ID도 없고 키워드도 없는 경우\nelse {\n  return [{ json: {} }];\n}\n\n\n// 다음 노드로 쿼리와 플래그를 함께 전달\nreturn [{\n  json: {\n    query: finalQuery,\n    isIdSearch: isIdSearch\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        160,
        -176
      ],
      "id": "b4a4a072-f47a-4e8d-879e-87c83127a3a5",
      "name": "Build Mongo Query"
    },
    {
      "parameters": {
        "jsCode": "// Stringify Mongo Query 노드 수정 코드\nconst input = $json;\nconst mongoQuery = input.query;\nconst isIdSearch = input.isIdSearch;\n\nlet outputJson;\n\nif (isIdSearch) {\n  // ID 검색일 경우, _id 필드만 남기고 JSON 객체로 반환\n  outputJson = {\n    _id: mongoQuery._id[\"$oid\"]\n  };\n} else {\n  // 키워드 검색일 경우, 쿼리 객체 그대로 반환\n  outputJson = mongoQuery;\n}\n\nreturn [\n  {\n    json: {\n      mongoQuery: JSON.stringify(outputJson)\n    }\n  }\n];"
      },
