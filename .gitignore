__pycache__/
*.py[cod]

node_modules

# Python virtual environment
venv/

# Log files
scripts/*.log

temp_downloads

# Claude Code local settings (개인 설정만 배제, skills는 공유)
.claude/settings.local.json

# PyInstaller build output (임시 파일)
build/
dist/
*.spec
# AC 빌드 스크립트는 추적 (소스 파일)
!tools/auto_clicker_v2/build/
tools/auto_clicker_v2/build/AutoClicker/
!tools/auto_clicker_v2/build/*.spec

# VSCode settings (개인 개발 환경)
.vscode/

# Environment variables (API keys, secrets)
backend/api/annual_report_api/.env
backend/api/*/.env

# 임시 네트워크 테스트 파일 (백그라운드 프로세스 출력)
tars.giize.com
nul
# TypeScript build cache
*.tsbuildinfo

# Build hash files (deployment smart build tracking)
.build_hash
_build_info.json
.requirements_hash
tmpclaude-*

# Sikuli screenshots (테스트 실행 중 생성)
tools/MetlifePDF.sikuli/screenshots/
tools/MetlifePDF.sikuli/debug_log.txt
*.class

# AutoClicker v2 output (실행 결과물)
tools/auto_clicker_v2/output/
tools/auto_clicker_v2/*.log
tools/auto_clicker_v2/.pause_signal

# Mobile responsive screenshots (Puppeteer 자동 캡처)
mobile/screenshots/
mobile/screenshots_*/
mobile/node_modules/
