{
  "name": "aims-uix3",
  "private": true,
  "version": "0.262.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:clean": "npm run clean && vite",
    "dev:force": "npm run clean:deps && vite --force",
    "dev:win": "powershell -Command \"if (Test-Path '.vite') { Remove-Item -Recurse -Force '.vite' }; if (Test-Path 'node_modules\\.vite') { Remove-Item -Recurse -Force 'node_modules\\.vite' }; if (Test-Path 'dist') { Remove-Item -Recurse -Force 'dist' }\" && vite",
    "test:hmr": "node test-hmr.js",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "clean": "rm -rf .vite && rm -rf node_modules/.vite && rm -rf dist",
    "clean:deps": "rm -rf .vite && rm -rf node_modules/.vite && rm -rf node_modules/.cache",
    "clean:all": "rm -rf .vite && rm -rf node_modules/.vite && rm -rf node_modules/.cache && rm -rf node_modules && rm -rf dist",
    "reset": "npm run clean:all && npm install",
    "release:patch": "npm version patch -m 'chore: 버전 %s' && git push --follow-tags",
    "release:minor": "npm version minor -m 'chore: 버전 %s' && git push --follow-tags",
    "release:major": "npm version major -m 'chore: 버전 %s' && git push --follow-tags"
  },
  "dependencies": {
    "@aims/excel-refiner-core": "*",
    "@tanstack/react-query": "^5.87.4",
    "axios": "^1.13.2",
    "pdfjs-dist": "^5.3.93",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-pdf": "^10.1.0",
    "react-router-dom": "^7.9.1",
    "xlsx": "^0.18.5",
    "zod": "^4.1.8",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@playwright/test": "^1.55.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.4.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "baseline-browser-mapping": "^2.9.7",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^27.0.0",
    "lint-staged": "^16.1.6",
    "playwright": "^1.55.1",
    "prettier": "^3.6.2",
    "terser": "^5.44.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.50.1"
  }
}
